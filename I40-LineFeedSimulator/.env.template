# =============================================================================
# LineFeed Simulator — Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in values before starting:
#   cp .env.template .env
#
# NEVER commit .env — only this template is safe to commit.
# =============================================================================

# -----------------------------------------------------------------------------
# Container image
# -----------------------------------------------------------------------------
# Published multi-arch LFS image (built from Dockerfile)
# Run: ./scripts/build-and-push-lfs  then paste the output here
# Example: ghcr.io/karltbraun/i40-lfs:2026-04-22.abc1234
LFS_IMAGE=

# -----------------------------------------------------------------------------
# MQTT broker
# -----------------------------------------------------------------------------
# Hostname or IP of the MQTT broker to publish to.
#
# Same host as I40-Stack (Mac):   host.docker.internal
# Same host as I40-Stack (Linux): use the host's LAN IP (not localhost)
# Remote host:                    hostname or IP of that machine
MQTT_BROKER=

# MQTT broker port (default 1883)
MQTT_PORT=1883
