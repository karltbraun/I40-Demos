#!/usr/bin/env bash
# Start the LineFeed Simulator container.
# Auto-selects the correct compose file for the current platform.
# Optional args are forwarded to lfs-restart after the container comes up.
#
# Usage:
#   ./start-lfs                      # start with defaults (--speed 5 --loop)
#   ./start-lfs --speed 10 --loop    # start then apply new parameters
set -euo pipefail

LFS_DIR="$(cd "$(dirname "$0")" && pwd)"

arch=$(uname -m)
os=$(uname -s)

if [[ "$arch" == "arm64" ]]; then
    COMPOSE_FILE="docker-compose.m3.yml"
elif [[ "$arch" == "x86_64" ]]; then
    COMPOSE_FILE="docker-compose.x86_64.yml"
else
    echo "ERROR: Unsupported platform: $os/$arch" >&2
    exit 1
fi

# ---------------------------------------------------------------------------
# Pre-flight
# ---------------------------------------------------------------------------
if [ ! -f "$LFS_DIR/.env" ]; then
    echo "ERROR: $LFS_DIR/.env not found." >&2
    echo "  Run: cp $LFS_DIR/.env.template $LFS_DIR/.env  and fill in values." >&2
    exit 1
fi

if ! docker info &>/dev/null; then
    echo "ERROR: Docker daemon is not running." >&2
    exit 1
fi

# ---------------------------------------------------------------------------
# Start the container
# ---------------------------------------------------------------------------
echo "Platform: $os/$arch"
echo "Compose:  $COMPOSE_FILE"

cd "$LFS_DIR"
docker compose -f "$COMPOSE_FILE" up -d --no-build

echo ""
echo "  Container:  i40-lfs"
echo "  Log:        $LFS_DIR/logs/simulator.log"
echo "  Restart:    docker exec i40-lfs lfs-restart --speed <N> --loop"
echo "  Stop:       docker compose -f $COMPOSE_FILE stop lfs"
echo ""

# ---------------------------------------------------------------------------
# Apply parameters if provided
# ---------------------------------------------------------------------------
if [[ $# -gt 0 ]]; then
    echo "Applying args: $*"
    docker exec i40-lfs lfs-restart "$@"
fi
