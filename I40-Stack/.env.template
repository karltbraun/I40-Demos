# =============================================================================
# I40 Demo Stack — Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in values before starting the stack:
#   cp .env.template .env
#
# NEVER commit .env — only this template is safe to commit.
# =============================================================================

# -----------------------------------------------------------------------------
# InfluxDB 3 Core
# -----------------------------------------------------------------------------
# Unique identifier for this InfluxDB node (used in WAL file naming)
INFLUXDB3_HOST_ID=influxdb-i40-demo

# ----------------------------------------------------------------------------
# Container images
# ----------------------------------------------------------------------------
# Published multi-arch Node-RED image (built from Dockerfile.nodered)
# Run: ./scripts/build-and-push-nodered  then paste the output here
# Example: ghcr.io/karltbraun/i40-nodered:2026-04-13.e414414
NODE_RED_IMAGE=

# Published multi-arch Ignition image (built from Dockerfile.ignition)
# Run: ./scripts/build-and-push-ignition  then paste the output here
# Example: ghcr.io/karltbraun/i40-ignition:2026-04-13.e414414
IGNITION_IMAGE=

# Published multi-arch InfluxDB image (built from Dockerfile.influxdb)
# Run: ./scripts/build-and-push-influxdb  then paste the output here
# Example: ghcr.io/karltbraun/i40-influxdb:2026-04-13.e414414
INFLUXDB_IMAGE=

# Published multi-arch Mosquitto image (built from Dockerfile.mosquitto)
# Run: ./scripts/build-and-push-mosquitto  then paste the output here
# Example: ghcr.io/karltbraun/i40-mosquitto:2026-04-13.e414414
MOSQUITTO_IMAGE=

# Published multi-arch Grafana image (built from Dockerfile.grafana)
# Run: ./scripts/build-and-push-grafana  then paste the output here
# Example: ghcr.io/karltbraun/i40-grafana:2026-04-13.e414414
GRAFANA_IMAGE=

# Database name for I40 demo data
INFLUXDB_DATABASE=i40demo

# Auth token — leave empty for InfluxDB 3 Core default (no auth)
# Set a value if you configure token-based auth on the InfluxDB instance
INFLUXDB_TOKEN=

# -----------------------------------------------------------------------------
# Grafana
# -----------------------------------------------------------------------------
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=

# -----------------------------------------------------------------------------
# Ignition
# Admin password is set via Docker secret (secrets/IGNITION_ADMIN_PASSWORD)
# -----------------------------------------------------------------------------
IGNITION_ADMIN_USERNAME=admin

# -----------------------------------------------------------------------------
# MQTT
# -----------------------------------------------------------------------------
# Root topic for I40 demo messages — Telegraf subscribes to ${MQTT_TOPIC_ROOT}/#
MQTT_TOPIC_ROOT=i40
